{
    "compilerOptions": {
        "module": "commonjs",
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "outDir": "lib",
        "sourceMap": true,
        "strict": true,
        "target": "es2017",
        "lib": [
            "es2018"
        ],
        "skipLibCheck": true,
        "types": []
    },
    "compileOnSave": true,
    "include": [
        "src"
    ]
}